{
  "name": "aido",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build-aido.mjs",
    "build:android:release-apk": "node scripts/build-android-release-apk.mjs",
    "build:android:store-aab": "node scripts/build-android-store-aab.mjs",
    "auth:production:refresh": "node scripts/refresh-production-auth.mjs",
    "auth:production:print-secret": "node scripts/print-production-auth-secret.mjs",
    "auth:production:set-github-secret": "node scripts/set-github-auth-secret.mjs",
    "capture:release:screenshots": "node scripts/capture-release-screenshots.mjs",
    "capture:release:screenshots:local": "node scripts/capture-release-screenshots.mjs --local",
    "doctor:mobile:preview": "node scripts/doctor-mobile-preview.mjs",
    "doctor:accounts": "node scripts/check-account-access.mjs",
    "doctor:production:auth": "node scripts/doctor-production-auth.mjs",
    "doctor:release": "node scripts/doctor-release.mjs",
    "release:manifest": "node scripts/write-release-manifest.mjs",
    "release:store-pack": "node scripts/write-store-submission-pack.mjs",
    "release:completion-report": "node scripts/check-release-completion.mjs --write-report",
    "release:completion-summary": "node scripts/check-release-completion.mjs --write-report --write-summary",
    "release:signoff:init": "node scripts/initialize-release-signoff.mjs",
    "release:signoff:mark": "node scripts/mark-release-signoff.mjs",
    "release:signoff:reset": "node scripts/initialize-release-signoff.mjs --force",
    "check:api": "corepack pnpm --filter @workspace/api-server run build",
    "check:android:release-apk": "node scripts/check-android-release-apk.mjs",
    "check:android:store": "node scripts/check-android-store.mjs",
    "check:android:store-aab": "node scripts/check-android-store-aab.mjs",
    "check:accounts": "node scripts/check-account-access.mjs",
    "check:all": "corepack pnpm run typecheck && corepack pnpm run build && corepack pnpm run check:api && corepack pnpm run check:deploy && corepack pnpm run check:completion-artifacts && corepack pnpm run check:mobile && corepack pnpm run check:release-assets",
    "check:completion-artifacts": "node scripts/check-release-completion.mjs --check-report --check-summary",
    "check:deploy": "node scripts/check-deploy-readiness.mjs",
    "check:ios:store": "node scripts/check-ios-store.mjs",
    "check:launch": "corepack pnpm run check:all && corepack pnpm run check:mobile:preview && corepack pnpm run check:parity && corepack pnpm run check:store && corepack pnpm run check:production",
    "check:launch:auth": "corepack pnpm run check:launch && corepack pnpm run check:production:auth",
    "check:launch:status": "node scripts/check-launch-status.mjs",
    "check:complete": "node scripts/check-release-completion.mjs",
    "check:complete:strict": "node scripts/check-release-completion.mjs --strict",
    "check:mobile": "node scripts/check-mobile.mjs",
    "check:mobile:preview": "node scripts/check-mobile-web-preview.mjs",
    "check:parity": "node scripts/check-parity-local.mjs",
    "check:production": "node scripts/check-production.mjs",
    "check:production:all": "corepack pnpm run check:production && corepack pnpm run check:production:auth",
    "check:production:auth": "node scripts/check-production-auth.mjs",
    "check:release-manifest": "node scripts/write-release-manifest.mjs --check",
    "check:store-pack": "node scripts/write-store-submission-pack.mjs --check",
    "check:release-assets": "node scripts/check-release-assets.mjs",
    "check:store": "corepack pnpm run check:android:release-apk && corepack pnpm run check:android:store && corepack pnpm run check:ios:store && corepack pnpm run check:release-assets && corepack pnpm run check:release-manifest && corepack pnpm run check:store-pack",
    "dev": "cd artifacts/aido && pnpm run dev",
    "preview:mobile:web": "corepack pnpm --dir mobile/app run web:preview",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test",
    "test:e2e:production": "node -e \"process.env.AIDO_BASE_URL='https://aidowedding.net'; require('child_process').spawnSync('playwright', ['test'], { stdio: 'inherit', shell: true, env: process.env });\"",
    "test:e2e:ci": "playwright test tests/aido-smoke.spec.ts tests/aido-user-journey.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc -b lib/api-client-react/tsconfig.json lib/object-storage-web/tsconfig.json && tsc -p artifacts/aido/tsconfig.json --noEmit"
  },
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
