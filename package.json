{
  "name": "aido",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "cd artifacts/aido && pnpm run build && cd ../.. && mkdir -p dist && cp -r artifacts/aido/dist/* dist/",
    "dev": "cd artifacts/aido && pnpm run dev",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test",
    "test:e2e:production": "node -e \"process.env.AIDO_BASE_URL='https://aidowedding.net'; require('child_process').spawnSync('playwright', ['test'], { stdio: 'inherit', shell: true, env: process.env });\"",
    "test:e2e:ci": "playwright test tests/aido-smoke.spec.ts tests/aido-user-journey.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc -b lib/api-client-react/tsconfig.json lib/object-storage-web/tsconfig.json && tsc -p artifacts/aido/tsconfig.json --noEmit"
  },
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
