{
  "name": "aido",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --dir artifacts/api-server run build && cd artifacts/aido && pnpm run build && cd ../.. && mkdir -p dist && cp -r artifacts/aido/dist/* dist/",
    "dev": "cd artifacts/aido && pnpm run dev",
    "render:build": "pnpm --dir artifacts/api-server run build",
    "render:start": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "start": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "typecheck": "tsc -p artifacts/aido/tsconfig.json --noEmit"
  },
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
