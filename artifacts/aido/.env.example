# ── Vercel Environment Variables ──────────────────────────────────────────────
# Set these in your Vercel project dashboard under Settings → Environment Variables

# Your Render backend URL (no trailing slash)
VITE_API_URL=https://ai-do.onrender.com

# Clerk publishable key (from clerk.com dashboard → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — point this at your Render backend so Clerk auth
# requests go through your server instead of directly to Clerk
VITE_CLERK_PROXY_URL=https://ai-do.onrender.com/clerk
